# Template for android/key.properties
# ============================================================
# Copy this file to android/key.properties and fill in the
# values for your keystore. NEVER commit key.properties to git.
# ============================================================

storePassword=<your-keystore-password>
keyPassword=<your-key-password>
keyAlias=<your-key-alias>
storeFile=<absolute-or-relative-path-to-your.jks>
